# Copy to .env.local and fill in values before running locally.
# Next.js only exposes variables prefixed with NEXT_PUBLIC_ to the browser.

# URL of the local API service
NEXT_PUBLIC_API_URL=http://localhost:3001

# Firebase project config — get these from the Firebase console
# (Project settings → Your apps → Web app → SDK setup and configuration)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Point the Firebase JS SDK at local emulators.
# Set to "true" to use emulators, "false" for production Firebase.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1
NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
NEXT_PUBLIC_AUTH_EMULATOR_URL=http://127.0.0.1:9099
