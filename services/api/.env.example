# Copy to .env and fill in values before running locally.

# Port the API HTTP server listens on.
# Must not clash with Firebase emulator ports (8080, 9099, 4000).
PORT=3001

# Firebase project ID (must match .firebaserc)
GCLOUD_PROJECT=your-firebase-project-id

# Point Firebase Admin SDK at local emulators.
# Remove these lines when deploying to Cloud Run — ADC handles production auth.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
