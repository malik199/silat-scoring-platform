{
  "name": "silat-scoring-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build:packages": "npm run build --workspace=packages/shared_types && npm run build --workspace=packages/shared_rules",
    "dev:api": "npm run dev --workspace=services/api",
    "dev:engine": "npm run dev --workspace=services/scoring_engine",
    "dev:web": "npm run dev --workspace=apps/web_admin_app"
  }
}
