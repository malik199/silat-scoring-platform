rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authenticated admins can read/write tournaments and competitors.
    // Scoring data (matches, score events) will get tighter rules once
    // role-based access is wired up.

    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /competitors/{competitorId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /judges/{judgeId} {
      allow read, write: if request.auth != null;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /scoreEvents/{eventId} {
        allow read: if true;
        allow create: if request.auth != null; // judges sign in via Google/Apple
      }

      match /adminEvents/{eventId} {
        allow read: if true;
        allow write: if request.auth != null; // admin only
      }
    }

    // Deny everything else until explicitly opened.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
